{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hushclaw.dev/schemas/ppt-deck-v1.2.json",
  "title": "ConsultingDeckSpec",
  "type": "object",
  "required": ["deck_meta", "storyline", "slides"],
  "additionalProperties": false,
  "properties": {
    "deck_meta": {
      "type": "object",
      "required": ["title", "language", "audience_level", "objective_type", "page_mode", "theme"],
      "additionalProperties": false,
      "properties": {
        "title": {"type": "string", "minLength": 3},
        "language": {"type": "string", "enum": ["zh-CN", "en-US"]},
        "audience_level": {"type": "string", "enum": ["exec", "manager", "analyst"]},
        "objective_type": {"type": "string", "enum": ["inform", "decide", "align", "review"]},
        "page_mode": {"type": "string", "enum": ["auto", "fixed", "range"]},
        "page_count": {"type": "integer", "minimum": 3, "maximum": 30},
        "page_count_min": {"type": "integer", "minimum": 3, "maximum": 30},
        "page_count_max": {"type": "integer", "minimum": 3, "maximum": 30},
        "theme": {"type": "string", "minLength": 1},
        "story_profile_name": {"type": "string"},
        "story_quality_target": {"type": "integer", "minimum": 70, "maximum": 100},
        "design_quality_target": {"type": "integer", "minimum": 70, "maximum": 100}
      }
    },
    "storyline": {
      "type": "object",
      "required": ["core_answer", "narrative_framework", "chapters"],
      "additionalProperties": false,
      "properties": {
        "core_answer": {"type": "string", "minLength": 8},
        "narrative_framework": {"type": "string", "enum": ["scqa", "pyramid", "issue_tree"]},
        "chapters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "intent"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string", "pattern": "^ch[0-9]+$"},
              "name": {"type": "string", "minLength": 2},
              "intent": {"type": "string", "minLength": 4}
            }
          }
        }
      }
    },
    "strategy_house": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aspiration": {"type": "string"},
        "objectives": {"type": "array", "items": {"type": "string"}},
        "initiatives": {"type": "array", "items": {"type": "string"}},
        "enablers": {"type": "array", "items": {"type": "string"}},
        "foundation": {"type": "string"}
      }
    },
    "slides": {
      "type": "array",
      "minItems": 3,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "id",
          "chapter_id",
          "template",
          "headline",
          "so_what",
          "proof_blocks",
          "visual_spec",
          "qc"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^s[0-9]{2,3}$"},
          "chapter_id": {"type": "string", "pattern": "^ch[0-9]+$"},
          "chapter_tag": {
            "type": "string",
            "enum": ["summary", "starting_point", "strategy_house", "initiative_deep_dive", "implementation_roadmap"]
          },
          "template": {
            "type": "string",
            "enum": [
              "title_opening",
              "exec_summary_3proof",
              "scqa_story",
              "issue_tree",
              "kpi_dashboard",
              "trend_line_insight",
              "compare_before_after",
              "waterfall_bridge",
              "segment_matrix_2x2",
              "option_tradeoff",
              "roadmap_quarterly",
              "decision_next_steps",
              "strategy_house_overview",
              "initiative_case_card",
              "impact_value_waterfall",
              "prioritization_impact_feasibility",
              "implementation_requirements_panel",
              "kpi_target_tracker"
            ]
          },
          "headline": {"type": "string", "minLength": 8},
          "key_question": {"type": "string", "minLength": 6},
          "subheadline": {"type": "string"},
          "so_what": {"type": "string", "minLength": 6},
          "logic_chain": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "claim": {"type": "string", "minLength": 6},
              "because": {"type": "array", "minItems": 1, "items": {"type": "string"}},
              "therefore": {"type": "string", "minLength": 6}
            }
          },
          "proof_blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "label"],
              "additionalProperties": false,
              "properties": {
                "type": {"type": "string", "enum": ["metric", "benchmark", "case", "experiment"]},
                "label": {"type": "string", "minLength": 2},
                "value": {"type": ["string", "number"]},
                "unit": {"type": "string"},
                "period": {"type": "string"}
              }
            }
          },
          "visual_spec": {
            "type": "object",
            "required": ["visual_type"],
            "additionalProperties": false,
            "properties": {
              "visual_type": {"type": "string", "enum": ["chart", "matrix", "process", "table", "cards", "none"]},
              "chart_type": {"type": "string", "enum": ["line", "bar", "stacked_bar", "waterfall", "none"]},
              "encoding": {"type": "object"}
            }
          },
          "design_tokens": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "icon_style": {"type": "string", "enum": ["outline", "filled", "duotone"]},
              "icon_keywords": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "visual_tone": {"type": "string", "enum": ["boardroom", "growth", "transformation", "risk_control"]},
              "layout_density": {"type": "string", "enum": ["airy", "balanced", "dense"]}
            }
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source_id", "name", "date", "confidence"],
              "additionalProperties": false,
              "properties": {
                "source_id": {"type": "string", "pattern": "^src_[0-9]{3,}$"},
                "name": {"type": "string", "minLength": 2},
                "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
                "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
              }
            }
          },
          "notes": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "assumptions": {"type": "array", "items": {"type": "string"}},
              "risks": {"type": "array", "items": {"type": "string"}},
              "next_actions": {"type": "array", "items": {"type": "string"}}
            }
          },
          "implementation": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "owner": {"type": "string"},
              "timeline": {"type": "string"},
              "requirements": {"type": "array", "items": {"type": "string"}},
              "success_kpis": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {"type": "string"},
                    "target": {"type": ["string", "number"]},
                    "by": {"type": "string"}
                  }
                }
              },
              "risks": {"type": "array", "items": {"type": "string"}},
              "next_steps": {"type": "array", "items": {"type": "string"}}
            }
          },
          "qc": {
            "type": "object",
            "required": ["must_pass"],
            "additionalProperties": false,
            "properties": {
              "must_pass": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "answer_first",
                    "one_message_per_slide",
                    "mece",
                    "evidence_present",
                    "source_required",
                    "number_consistency",
                    "density_limit",
                    "actionability_required"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "global_sources": {"type": "array"},
    "extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domain": {"type": "object", "additionalProperties": true},
        "localization": {"type": "object", "additionalProperties": true},
        "brand_style": {"type": "object", "additionalProperties": true}
      }
    }
  }
}
